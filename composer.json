{
    "name": "mindef/demo",
    "description": "Proyecto MVC demo",
    "type": "project",
    "config": {
        "platform-check": false
    },
    "autoload": {
        "psr-4": {
            "MVC\\" : "./",
            "Controllers\\" : "./controllers",
            "Model\\" : "./models",
            "Classes\\" : "./classes"
        }
    },
    "require": {
        "mpdf/mpdf": "^8.3",
        "phpmailer/phpmailer": "^6.6",
        "dompdf/dompdf": "^2.0",
        "vlucas/phpdotenv": "^5.5",
        "phpseclib/phpseclib": "~3.0",
        "setasign/fpdi": "^2.6",
        "setasign/fpdf": "^1.8",
        "resend/resend-php": "^0.1"
    }
}
